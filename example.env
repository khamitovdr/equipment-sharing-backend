# FastAPI app settings
ENVIRONMENT=dev
TESTING=false

# Required: DB connection for Tortoise ORM (service name 'web-db' is the host inside Compose network)
DATABASE_URL=postgres://postgres:postgres@web-db:5432/web_dev

# Required: JWT signing key (generate with: openssl rand -hex 32)
SECRET_KEY=change_me_to_a_random_hex_string

# Optional: where static files are served from (default is static/)
STATIC_DIR=static/

# Optional: Sentry (leave empty to disable)
# SENTRY_DSN=

# Optional: YooKassa (payments)
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=

# Optional: ChatEngine (in-app chat)
# CHAT_ENGINE_PROJECT_ID=
# CHAT_ENGINE_SECRET_KEY=